# ============================================================
# Byte x402 Gateway Configuration
# ============================================================

# HTTP server port
PORT=3402

# Wallet address that receives x402 payments (USDC)
# Default is Hardhat account #0 -- replace with your own address
PAY_TO_ADDRESS=0xYourWalletAddressHere

# x402 facilitator URL for payment verification
FACILITATOR_URL=https://facilitator.x402.org

# CAIP-2 network identifier
# Arbitrum Sepolia (testnet): eip155:421614
# Arbitrum One (mainnet):     eip155:42161
NETWORK=eip155:421614

# Price per request in USD
REQUEST_PRICE=0.001

# Data source cache TTL in seconds
CACHE_TTL=60

# Optional: CoinGecko API key for higher rate limits
# Get one free at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Optional: Byte Protocol indexer URL for on-chain status data
# Only needed if running the byte-status feed with live data
BYTE_INDEXER_URL=http://localhost:4000
